LOCATE COMP "SD_DQ[0]" SITE "L15" ;IOBUF PORT "SD_DQ[0]" IO_TYPE=LVCMOS33 PULLMODE=NONE DRIVE=8 SLEWRATE=SLOW CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=3.3 HYSTERESIS=NA TERMINATION=OFF ;
