IOBUF ALLPORTS IO_TYPE=LVCMOS33 ;
# =========================
# CLOCKS  (use real clock-capable pins if possible)
# =========================
LOCATE COMP "CRYSTAL" SITE "M1" ;
IOBUF PORT "CRYSTAL" IO_TYPE=LVCMOS33 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=3.3 HYSTERESIS=ON TERMINATION=OFF ;
# =========================
# CAMERA SYNC + DATA (inputs)
# =========================
LOCATE COMP "VSYNC" SITE "B10" ;IOBUF PORT "VSYNC" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "HREF" SITE "A11" ;IOBUF PORT "HREF" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y9" SITE "B11" ;IOBUF PORT "Y9" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y8" SITE "B12" ;IOBUF PORT "Y8" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y7" SITE "A13" ;IOBUF PORT "Y7" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y6" SITE "A14" ;IOBUF PORT "Y6" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y5" SITE "A15" ;IOBUF PORT "Y5" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y4" SITE "C13" ;IOBUF PORT "Y4" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y3" SITE "C12" ;IOBUF PORT "Y3" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
LOCATE COMP "Y2" SITE "B14" ;IOBUF PORT "Y2" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
# Camera MCLK (output)
LOCATE COMP "MCLK" SITE "A12" ;IOBUF PORT "MCLK" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=8 SLEWRATE=SLOW CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
# SCCB / I2C (camera control)
LOCATE COMP "cam_scl" SITE "A10" ; IO_TYPE PORT "cam_scl" IO_TYPE=LVCMOS18 DRIVE=4 SLEWRATE=SLOW ;
LOCATE COMP "cam_sda" SITE "B9" ; IO_TYPE PORT "cam_sda" IO_TYPE=LVCMOS18 OPENDRAIN=ON ; 
LOCATE COMP "PCLK" SITE "C8" ;IOBUF PORT "PCLK" IO_TYPE=LVCMOS18 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=1.8 HYSTERESIS=NA TERMINATION=OFF ;
# =========================
# SDRAM (ALL EXPLICITLY LVCMOS33)
# =========================
