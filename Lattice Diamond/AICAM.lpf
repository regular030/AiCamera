LOCATE COMP "SSPI_CS_n" SITE "R1" ;IOBUF PORT "SSPI_CS_n" IO_TYPE=LVCMOS33 PULLMODE=UP DRIVE=NA SLEWRATE=NA CLAMP=ON OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=3.3 HYSTERESIS=ON TERMINATION=OFF ;
