# ESP32 <-> FPGA SPI  (move off config-only bank; keep in a 3.3 V bank)
# =========================
LOCATE COMP "DIN" SITE "T8" ;IOBUF PORT "DIN" IO_TYPE=LVCMOS33 PULLMODE=NONE DRIVE=NA SLEWRATE=NA CLAMP=OFF OPENDRAIN=OFF DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=2.5 HYSTERESIS=ON TERMINATION=OFF ;
LOCATE COMP "DOUT" SITE "M8" ;IOBUF PORT "DOUT" IO_TYPE=LVCMOS33 PULLMODE=NONE DRIVE=8 SLEWRATE=SLOW CLAMP=OFF OPENDRAIN=ON DIFFRESISTOR=OFF DIFFDRIVE="NA" BANK_VCCIO=2.5 HYSTERESIS=NA TERMINATION=OFF ;
